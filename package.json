{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "expo": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build:api": "npm install --prefix backend-fastify --omit=dev && node scripts/build-backend.mjs",
    "test:mongo": "node scripts/test-mongo.mjs",
    "postinstall": "npm run build:api",
    "start": "node dist/server.cjs",
    "start:api": "node server.js",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@google/genai": "^1.29.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.2.1",
    "dotenv": "^17.2.3",
    "esbuild": "^0.25.0",
    "expo": "~54.0.0",
    "expo-av": "~15.0.0",
    "expo-camera": "~16.0.0",
    "expo-screen-capture": "~6.0.0",
    "expo-status-bar": "~3.0.9",
    "express": "^4.21.2",
    "firebase": "^12.13.0",
    "lucide-react": "^0.546.0",
    "lucide-react-native": "^0.475.0",
    "motion": "^12.23.24",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-router-dom": "^7.15.1",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "~19.1.10",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "vite": "^6.2.3"
  }
}
