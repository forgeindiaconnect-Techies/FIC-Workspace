# Render → workspace-backend-r9f8 → Environment
# Copy each line as a separate variable (do NOT commit real passwords to GitHub)

NODE_ENV=production

# Get from Atlas: Database → Connect → Drivers → Node.js
# If password contains @, encode it: @ → %40
# Example password "MyPass@123" becomes "MyPass%40123" in the URI
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@pmt.kiqc6ip.mongodb.net/nexus-zoom?retryWrites=true&w=majority

JWT_SECRET=use-a-long-random-string-here
JWT_REFRESH_SECRET=use-another-long-random-string-here

# Atlas checklist:
# 1. Database Access → create user OR reset password (simple letters+numbers is easiest)
# 2. Network Access → Add IP → Allow Access from Anywhere (0.0.0.0/0)
# 3. Paste MONGO_URI above into Render → Save → wait for redeploy
# 4. Open https://workspace-backend-r9f8.onrender.com/health → database must be "connected"
