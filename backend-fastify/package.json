{
  "name": "nexus-zoom-backend",
  "version": "1.0.0",
  "description": "Production-ready Zoom-like meeting backend service using Fastify, MongoDB, Redis, and WebRTC Mediasoup SFU",
  "main": "dist/index.js",
  "scripts": {
    "build": "node -e \"require('esbuild').buildSync({entryPoints:['src/index.ts'],outfile:'dist/index.js',bundle:true,platform:'node',target:'node20',format:'cjs',packages:'external',sourcemap:true})\" && echo Build complete",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.0.0",
    "@fastify/websocket": "^10.0.1",
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.10.0",
    "dotenv": "^16.4.5",
    "esbuild": "^0.25.0",
    "fastify": "^4.26.2",
    "firebase-admin": "^14.1.0",
    "groq-sdk": "^1.2.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.2.4",
    "pino-pretty": "^13.1.3",
    "puppeteer": "^25.0.4",
    "qrcode": "^1.5.3",
    "speakeasy": "^2.0.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.30",
    "@types/qrcode": "^1.5.5",
    "@types/speakeasy": "^2.0.10",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "tsx": "^4.7.1",
    "typescript": "^5.4.3"
  }
}
