# Server Configuration
PORT=3001
HOST=0.0.0.0

# Security secrets
JWT_SECRET=nexus-jwt-secure-key-change-in-production
JWT_REFRESH_SECRET=nexus-refresh-secret-key-change-in-production

# Primary Databases
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/nexus-zoom?retryWrites=true&w=majority
REDIS_URL=redis://127.0.0.1:6379

# Cloudflare R2 / S3 Storage (Optional for recordings)
S3_ACCESS_KEY_ID=your-r2-access-key-id
S3_SECRET_ACCESS_KEY=your-r2-secret-access-key
S3_ENDPOINT=https://your-cloudflare-r2-account-id.r2.cloudflarestorage.com
S3_BUCKET_NAME=nexus-zoom-recordings
