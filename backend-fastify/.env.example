# Backend environment variables for the Fastify server
# Copy this file to backend-fastify/.env and set the values.

# ── Required ──────────────────────────────────────────────
MONGO_URI="mongodb://127.0.0.1:27017/nexus-zoom"
JWT_SECRET="CHANGE_ME_generate_with_node_e_require_crypto_randomBytes_64_toString_hex"
JWT_REFRESH_SECRET="CHANGE_ME_generate_a_different_64_byte_hex_string"

# ── Cloudinary (file uploads) ─────────────────────────────
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
CLOUDINARY_FOLDER="your_upload_folder"

# ── AI Services ───────────────────────────────────────────
GROQ_API_KEY="your_groq_api_key"
GEMINI_API_KEY="your_gemini_api_key"

# ── TURN Server (WebRTC) ─────────────────────────────────
TURN_SERVER_URL="turn:your-turn-server:3478"
TURN_USERNAME="your_turn_username"
TURN_CREDENTIAL="your_turn_credential"

# ── Redis (optional, falls back to in-memory) ─────────────
# REDIS_URL="redis://127.0.0.1:6379"

# ── Seed Account (optional, random if unset) ──────────────
# SEED_ADMIN_PASSWORD="change_me_on_first_login"
